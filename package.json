{
  "name": "@carlgra/gitlore",
  "version": "0.1.0",
  "description": "Turn git history into engaging narratives, devlogs, and stories",
  "type": "module",
  "bin": {
    "gitlore": "./dist/bin/gitlore.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx bin/gitlore.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["git", "changelog", "narrative", "devlog", "storytelling", "blog", "history"],
  "author": "Graham Carle",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/carlgra/gitlore"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "date-fns": "^4.1.0",
    "ora": "^8.2.0",
    "simple-git": "^3.27.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
